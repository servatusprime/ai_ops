{
  "_comment": "ai_ops global settings template. Apply to ~/.claude/settings.json on new machine onboarding. Replace <workspace-root> with your actual workspace path in additionalDirectories.",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Read(**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git branch:*)",
      "Bash(git add:*)",
      "Bash(git -C:*)",
      "Bash(git ls-remote:*)",
      "Bash(git check-ignore:*)",
      "Bash(git mv:*)",
      "Bash(git checkout:*)",
      "Bash(git rm:*)",
      "Bash(git reset:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(findstr:*)",
      "Bash(cat:*)",
      "Bash(ls:*)",
      "Bash(dir:*)",
      "Bash(find:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(pwd:*)",
      "Bash(echo:*)",
      "Bash(sort:*)",
      "Bash(test:*)",
      "Bash(where:*)",
      "Bash(python:*)",
      "Bash(python3:*)",
      "Bash(py:*)",
      "Bash(node:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(pip:*)",
      "Bash(conda:*)",
      "Bash(pre-commit run:*)",
      "Bash(powershell -NoProfile:*)",
      "Bash(pwsh:*)",
      "Bash(gh:*)",
      "Bash(curl:*)",
      "Bash(bash .ai_ops/setup/*.sh:*)",
      "Bash(bash ai_ops/.ai_ops/setup/*.sh:*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials*)",
      "Bash(rm -rf:*)",
      "Bash(*--force push*)",
      "Bash(*git push --force*)",
      "Bash(*git push*--delete*)"
    ]
  },
  "effortLevel": "high",
  "additionalDirectories": [
    "<workspace-root>\\ai_ops\\.claude\\skills",
    "<workspace-root>\\.claude\\skills",
    "<workspace-root>\\ai_ops\\.git\\hooks"
  ]
}
